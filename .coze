[project]
requires = ["python-3.12"]

[dev]
build = ["python", "-m", "pip", "install", "-r", "requirements.txt"]
run = ["sh", "-c", "python -m uvicorn web.backend.app:app --host 0.0.0.0 --port ${DEPLOY_RUN_PORT}"]

[deploy]
build = ["python", "-m", "pip", "install", "-r", "requirements.txt"]
run = ["sh", "-c", "python -m uvicorn web.backend.app:app --host 0.0.0.0 --port ${DEPLOY_RUN_PORT}"]